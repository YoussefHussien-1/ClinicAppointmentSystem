<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.clinicappointmentsystem.controllers.TableViewController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="25.0" left="30.0" right="30.0" top="20.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Button onAction="#handleBackToMenu" prefHeight="35.0" prefWidth="110.0"
                                style="-fx-background-color: white; -fx-text-fill: #2c3e50; -fx-border-color: #dcdde1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"
                                text="⬅ Back" />
                        <Label text="Patient Records &amp; Appointments" textFill="#2980b9">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
                    <children>
                        <Label text="🔍 Search:" style="-fx-font-weight: bold;" textFill="#34495e">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <TextField fx:id="searchField" prefHeight="40.0" promptText="Enter Patient Name or ID..." HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 8; -fx-border-color: #f1f2f6; -fx-border-radius: 8;" />
                        <Button onAction="#handleDelete" prefHeight="40.0" prefWidth="180.0"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                                text="Cancel Appointment" />
                    </children>
                </HBox>

                <TableView fx:id="appointmentsTable" style="-fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10; -fx-overflow-x: hidden;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colPatientName" prefWidth="200.0" text="Patient Name" />
                        <TableColumn fx:id="colDoctorName" prefWidth="180.0" text="Doctor" />
                        <TableColumn fx:id="colDate" prefWidth="150.0" text="Date" />
                        <TableColumn fx:id="colTime" prefWidth="120.0" text="Time" />
                        <TableColumn fx:id="colStatus" prefWidth="150.0" text="Status" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label text="💡 Tip:" style="-fx-font-weight: bold;" textFill="#7f8c8d" />
                        <Label text="Select a record and click 'Cancel Appointment' to update the status." textFill="#95a5a6">
                            <font>
                                <Font name="System Italic" size="13.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>